# UniTask Environment Configuration Template
# Copy this file to .env and fill in your actual keys.

# COMMON
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket
FIREBASE_AUTH_DOMAIN=your-auth-domain

# WEB / FIRECMS (Vite variables)
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_APP_ID=your-web-app-id

# FLUTTER (Local dev)
FLUTTER_FIREBASE_API_KEY_WEB=your-web-api-key
FLUTTER_FIREBASE_API_KEY_ANDROID=your-android-api-key
FLUTTER_FIREBASE_API_KEY_IOS=your-ios-api-key

FLUTTER_FIREBASE_APP_ID_WEB=your-web-app-id
FLUTTER_FIREBASE_APP_ID_ANDROID=your-android-app-id
FLUTTER_FIREBASE_APP_ID_IOS=your-ios-app-id

# ANDROID SIGNING (Inject via GitHub Secrets for CI/CD)
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
ANDROID_STORE_FILE=
ANDROID_STORE_PASSWORD=
