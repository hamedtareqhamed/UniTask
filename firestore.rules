rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'hamedalbazly70@gmail.com';
    }

    // User Backups: Only the owner can read/write their own data
    match /backups/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Ready-made course templates: Publicly READ-ONLY, Admin WRITE
    match /ready_made_courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /assessments/{assessmentId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /ready_made_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
  }
}